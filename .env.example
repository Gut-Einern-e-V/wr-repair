# Public application URL. Use the Vercel production domain after the first deployment.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase browser client. These values are public by design.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_with_your_key

# Supabase server client. Never prefix this variable with NEXT_PUBLIC_ and never commit its value.
SUPABASE_SERVICE_ROLE_KEY=replace_with_your_service_role_key

# Friendly Captcha v2. The sitekey starts with FC and is safe in the browser; the API key is server-only.
NEXT_PUBLIC_FRIENDLY_CAPTCHA_SITEKEY=FC_replace_with_your_sitekey
FRIENDLY_CAPTCHA_API_KEY=replace_with_your_friendly_captcha_api_key

# Submission window, in ISO 8601 with an explicit timezone.
SUBMISSION_START_AT=2026-10-01T00:00:00+02:00
SUBMISSION_END_AT=2026-10-31T23:59:59+01:00

# Local development only: permits submissions without Vercel's NRW geo headers.
# Do not set this in Vercel, Preview, or Production.
GEOIP_ALLOW_LOCAL=false

# Comma-separated trusted origins for future server-side CORS checks.
ALLOWED_ORIGINS=http://localhost:3000